# 🚀 INDI Digital Card - Production Environment Template
# ⚠️  NEVER commit actual production values to Git!
# 🔐 Set these variables in your hosting platform (Vercel, Railway, etc.)

# Application
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-domain.com

# 🔐 Supabase Configuration
DB_TYPE=supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# 🔐 JWT Secrets (Use crypto.randomBytes(64).toString('hex'))
JWT_SECRET=your-cryptographically-secure-jwt-secret-64-chars
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your-cryptographically-secure-refresh-secret-64-chars
JWT_REFRESH_EXPIRE=7d

# 🔐 Security Keys (Use crypto.randomBytes(32).toString('hex'))
ENCRYPTION_KEY=your-32-byte-encryption-key-64-chars
SESSION_SECRET=your-session-secret-64-chars

# 🔐 Redis (Optional - for caching)
REDIS_URL=redis://your-redis-url:6379

# 🔐 Third Party APIs (Optional - as needed)
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-secret
# GEMINI_API_KEY=your-google-gemini-api-key
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# 🔐 Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 🔐 Monitoring (Optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
# LOG_LEVEL=info

# Production flags
MOCK_DATABASE=false
MOCK_REDIS=false
DATABASE_SSL=true